{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compose agent instruction files ruleset",
  "type": "object",
  "additionalProperties": false,
  "required": ["sources", "profile"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "global": {
      "type": "boolean",
      "description": "Write rules/global to user-global instruction files."
    },
    "output": {
      "type": "string",
      "minLength": 1
    },
    "claude": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "output": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalTokens": {
          "type": "integer",
          "minimum": 1
        },
        "moduleTokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
